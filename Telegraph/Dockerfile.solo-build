FROM rust:1.87-slim as builder

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /usr/src

# Copy entire workspace (for efficient dependency building)
COPY . .

# Build only the Telegraph service
RUN cargo build --release --bin telegraph-service
