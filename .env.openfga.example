# OpenFGA env-var overrides for every service that consumes the centralized
# authorization store. Copy the bits you need into your service-specific .env
# (for example IAMRusty/.env, Hive/.env, Manifesto/.env, Telegraph/.env) or
# set them in your shell before running cargo / docker compose.
#
# Each service uses its own env prefix because rustycog-config namespaces
# config-file overrides per service (HIVE_*, MANIFESTO_*, TELEGRAPH_*,
# SENTINEL_SYNC_*). The double-underscore separator binds env vars onto
# nested config sections (`HIVE_OPENFGA__STORE_ID` -> `[openfga]` ->
# `store_id`).
#
# `scheme` / `host` / `port` are split (instead of a single `api_url`) to
# mirror the [database] / [queue] convention. Set `*_OPENFGA__PORT=0` to
# ask `OpenFgaClientConfig::actual_port()` to bind a free random host port
# (used by the integration test fixture so multiple test binaries can run
# parallel OpenFGA containers without clashing on a fixed port).
#
# After running OpenFGA you can bootstrap a store + model with the fga CLI:
#   fga store create --name aiforall --api-url http://localhost:8090
#   fga model write --store-id <ID> --file openfga/model.fga \
#       --api-url http://localhost:8090
# then plug the generated ids below.

# ---- Hive -----------------------------------------------------------------
HIVE_OPENFGA__SCHEME=http
HIVE_OPENFGA__HOST=localhost
HIVE_OPENFGA__PORT=8090
HIVE_OPENFGA__STORE_ID=
HIVE_OPENFGA__AUTHORIZATION_MODEL_ID=
# HIVE_OPENFGA__API_TOKEN=

# ---- Manifesto ------------------------------------------------------------
MANIFESTO_OPENFGA__SCHEME=http
MANIFESTO_OPENFGA__HOST=localhost
MANIFESTO_OPENFGA__PORT=8090
MANIFESTO_OPENFGA__STORE_ID=
MANIFESTO_OPENFGA__AUTHORIZATION_MODEL_ID=
# MANIFESTO_OPENFGA__API_TOKEN=

# ---- Telegraph ------------------------------------------------------------
TELEGRAPH_OPENFGA__SCHEME=http
TELEGRAPH_OPENFGA__HOST=localhost
TELEGRAPH_OPENFGA__PORT=8090
TELEGRAPH_OPENFGA__STORE_ID=
TELEGRAPH_OPENFGA__AUTHORIZATION_MODEL_ID=
# TELEGRAPH_OPENFGA__API_TOKEN=

# ---- sentinel-sync (worker) -----------------------------------------------
SENTINEL_SYNC_OPENFGA__SCHEME=http
SENTINEL_SYNC_OPENFGA__HOST=localhost
SENTINEL_SYNC_OPENFGA__PORT=8090
SENTINEL_SYNC_OPENFGA__STORE_ID=
SENTINEL_SYNC_OPENFGA__AUTHORIZATION_MODEL_ID=
# SENTINEL_SYNC_OPENFGA__API_TOKEN=

# ---- Network-scoped overrides ---------------------------------------------
# When running inside the docker-compose network use the service hostname
# (and the container's internal port :8080) instead of localhost:8090:
#   HIVE_OPENFGA__HOST=openfga
#   HIVE_OPENFGA__PORT=8080
#   MANIFESTO_OPENFGA__HOST=openfga
#   MANIFESTO_OPENFGA__PORT=8080
#   TELEGRAPH_OPENFGA__HOST=openfga
#   TELEGRAPH_OPENFGA__PORT=8080
#   SENTINEL_SYNC_OPENFGA__HOST=openfga
#   SENTINEL_SYNC_OPENFGA__PORT=8080
